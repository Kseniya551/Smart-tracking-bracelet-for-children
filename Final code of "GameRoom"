  Serial.println("Connecting"); // מדפיסים הודעה מתאימה במסך הסריאלי
  while (WiFi.status() != WL_CONNECTED) {    
//לולאה שמתקיימת כל עוד לא הבקר לא התחבר לאינטרנט
    delay(500);   //השהייה של חצי שניה
    Serial.print("."); //מדפיסים במסך הסריאלי נקודה
  }
  Serial.println("");   //יורדים שורה במסך הסריאלי
  Serial.print("Connected to WiFi network with IP Address: "); //מדפיסים הודעה מתאימה
  Serial.println(WiFi.localIP());   //מדפיסים במסך הסריאלי את הכתובת שאליה התחברנו לאינטרנט

  Serial.println("Timer set to 5 seconds (timerDelay variable), it will take 5 seconds before publishing the first reading."); //מדפיסים הודעה מתאימה למסך הסריאלי


lcd.init();  
  lcd.clear();         // LCDמנקים את כל מה שכתוב על ה
  lcd.backlight();  //LCDמדליקים את האור האחורי של ה

  pinMode(button1, INPUT);    //מגדירים את הכפתור ה1 בתור קלט
  pinMode(button2, INPUT); //מגדירים את הכפתור ה2 בתור קלט
  pinMode(button3, INPUT); //מגדירים את הכפתור ה3 בתור קלט
